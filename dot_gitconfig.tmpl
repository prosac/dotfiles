[user]
	name = {{ .name }}
	email = {{ .email }}
	signingKey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMs6HiJPj7ByOObyp4an717pj59VjUZbCjdxO7LX/aa5 {{ .email }}
[gpg]
	format = ssh
[gpg "ssh"]
	program = {{ if eq .chezmoi.os "linux" }}/opt/1Password/op-ssh-sign{{ else }}/Applications/1Password.app/Contents/MacOS/op-ssh-sign{{ end }}
	allowedSignersFile = ~/.config/git/allowed-signers
[commit]
	gpgsign = true
[init]
	defaultBranch = main
[core]
	autocrlf = input
