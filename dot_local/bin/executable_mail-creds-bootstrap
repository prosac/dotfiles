#!/usr/bin/env bash
# mail-creds-bootstrap — one-shot helper to seal the credentials file
# that `gmi auth` writes to disk into a TPM2-bound blob, then shred the
# plaintext local copy.
#
# Run this exactly once after the interactive OAuth flow:
#
#   1. gmi init <email>              # creates ~/.local/share/mail/gmail/
#   2. cd ~/.local/share/mail/gmail
#   3. gmi auth                       # opens browser → FIDO2-backed Google sign-in
#      ^ writes <maildir>/.credentials.gmailieer.json in plaintext on disk
#   4. mail-creds-bootstrap           # this script: TPM-seal, shred local
#   5. mail-sync                       # ongoing path: tmpfs only
#
# The sealed blob is bound to PCR 7 (Secure Boot policy) on this machine's
# TPM. It cannot be decrypted on another machine or after a Secure Boot
# config change. To migrate to a new laptop you re-run `gmi auth` and
# `mail-creds-bootstrap` there.
#
# Idempotent: if a sealed blob already exists at $CRED_FILE, it gets
# overwritten atomically. Refuses to run if no local plaintext file is
# present (you'd be sealing nothing).

set -euo pipefail

MAILDIR="${LIEER_MAILDIR:-$HOME/.local/share/mail/gmail}"
CRED_FILE="${LIEER_CRED_FILE:-$HOME/.local/share/mail/lieer-creds.cred}"
PLAIN_FILE="$MAILDIR/.credentials.gmailieer.json"

log() { printf '[mail-creds-bootstrap] %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

command -v systemd-creds >/dev/null || die "systemd-creds not on PATH"
command -v jq >/dev/null || die "jq not on PATH"

[ -f "$PLAIN_FILE" ] || die "no credentials file at $PLAIN_FILE — did you run 'gmi auth'?"
# Guard against a leftover symlink from a previous mail-sync run.
[ -L "$PLAIN_FILE" ] && die "$PLAIN_FILE is a symlink — looks like mail-sync state, not a fresh 'gmi auth' output"

jq -e '.refresh_token' "$PLAIN_FILE" >/dev/null \
  || die "$PLAIN_FILE has no refresh_token — re-run 'gmi auth' with --scope=modify (or similar)"

mkdir -p "$(dirname "$CRED_FILE")"
tmp_sealed=$(mktemp "$CRED_FILE.XXXXXX")
trap 'rm -f "$tmp_sealed"' EXIT INT TERM

log "sealing credentials to TPM (PCR 7) at $CRED_FILE ..."
systemd-creds encrypt --tpm2-pcrs=7 --name=lieer-creds.cred "$PLAIN_FILE" "$tmp_sealed"
chmod 600 "$tmp_sealed"
mv -f "$tmp_sealed" "$CRED_FILE"

# Smoke-test: confirm the blob round-trips before we shred the plaintext.
if ! systemd-creds decrypt "$CRED_FILE" - >/dev/null; then
  die "sealed blob failed to decrypt — refusing to shred plaintext at $PLAIN_FILE"
fi

log "shredding local plaintext credentials..."
if command -v shred >/dev/null; then
  shred -u "$PLAIN_FILE"
else
  rm -f "$PLAIN_FILE"
fi

log "done. Credentials now live only in TPM-sealed form at $CRED_FILE."
log "Run 'mail-sync' to verify."
