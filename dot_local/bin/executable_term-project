#!/usr/bin/env python3
"""Fuzzy-pick a repo under ~/repos (via walker --dmenu) and open a ghostty
window for it with the project name as a faint background banner.

Bound to a Hyprland key. Runs in the GUI-session PATH (/usr/local/bin:/usr/bin),
so ~/.local/bin tools are invoked by absolute path. The opened window cd's into
the repo, so term-ident's tint/border follow automatically.
"""
import os
import subprocess
import sys

HOME = os.path.expanduser("~")
REPOS = os.path.join(HOME, "repos")
TERM_BANNER = os.path.join(HOME, ".local/bin/term-banner")
BANNER_OPACITY = "0.10"


def pick(entries: list[str]) -> str | None:
    try:
        r = subprocess.run(["walker", "--dmenu"], input="\n".join(entries),
                           capture_output=True, text=True)
    except (OSError, subprocess.SubprocessError):
        return None
    return r.stdout.strip() or None


def banner_for(name: str) -> str | None:
    try:
        p = subprocess.run([TERM_BANNER, name], capture_output=True,
                           text=True, timeout=10).stdout.strip()
        return p if p and os.path.exists(p) else None
    except (OSError, subprocess.SubprocessError):
        return None


def main() -> int:
    if not os.path.isdir(REPOS):
        return 1
    entries = sorted(d for d in os.listdir(REPOS) if os.path.isdir(os.path.join(REPOS, d)))
    if not entries:
        return 0
    name = pick(entries)
    if not name or not os.path.isdir(os.path.join(REPOS, name)):
        return 0

    args = ["ghostty", f"--working-directory={os.path.join(REPOS, name)}"]
    banner = banner_for(name)
    if banner:
        args += [f"--background-image={banner}",
                 f"--background-image-opacity={BANNER_OPACITY}",
                 "--background-image-position=bottom-right",
                 "--background-image-fit=none"]
    subprocess.Popen(args, start_new_session=True,
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                     stdin=subprocess.DEVNULL)
    return 0


if __name__ == "__main__":
    sys.exit(main())
