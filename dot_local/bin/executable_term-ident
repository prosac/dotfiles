#!/usr/bin/env python3
"""term-ident — give a ghostty window a stable visual identity from a seed.

A seed string is hashed to a hue, which drives two coordinated cues so that
parallel terminals are recognizable at a glance:

  - a subtle, theme-aware BACKGROUND tint   (OSC 11 -> the controlling tty)
  - a vivid per-window BORDER gradient        (hyprctl dispatch setprop)

Border is the strong, theme-independent cue; the bg tint is the peripheral
bonus. Degrades to a no-op outside Hyprland / when not running under ghostty.

Usage:
  term-ident project [dir]   seed from the git toplevel of dir (default $PWD);
                             resets to defaults when dir is not in a repo
  term-ident seed <string>   seed from an arbitrary string
  term-ident reset           clear tint + border (back to theme defaults)

Env:
  TERM_IDENT_TTY   tty to receive OSC sequences (default /dev/tty)
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
import zlib

TTY = os.environ.get("TERM_IDENT_TTY", "/dev/tty")

# Cool accents from the theme palette (Doom One + doom-emacs extended). Every
# tint derives from one of these, so colors always sit on-theme. Edit the list
# to retune the palette; backgrounds are these accents blended into the theme
# background, borders are the accents themselves.
PALETTE = ("#4db5bb", "#46d9ff", "#51afef", "#2257a0", "#a9a1e1", "#c678dd")
#           teal       cyan       blue       dark-blue  violet     magenta

# Per-scheme theme background + how much accent to blend in for the bg tint.
THEME = {
    "dark":  {"bg": "#282c34", "frac": 0.28, "border_darken": 0.00},
    "light": {"bg": "#f9f9f9", "frac": 0.20, "border_darken": 0.30},
}


def run(*args: str) -> str | None:
    """Run a command, returning stripped stdout or None on any failure."""
    try:
        out = subprocess.run(args, capture_output=True, text=True, timeout=2)
    except (OSError, subprocess.SubprocessError):
        return None
    return out.stdout.strip() if out.returncode == 0 else None


def ghostty_address() -> str | None:
    """Walk the /proc ppid chain to the ghostty process, then map its PID to a
    Hyprland window address.

    Hyprland-only: the per-window border tint is set via `hyprctl setprop`, which
    has no niri equivalent (niri can't recolor a single window's border at
    runtime). Under niri this returns None, so the border step no-ops while the
    OSC-11 background tint — which is just a terminal escape — still applies."""
    if os.environ.get("XDG_CURRENT_DESKTOP") != "Hyprland" or not _have("hyprctl"):
        return None
    pid, gpid = os.getpid(), None
    for _ in range(16):
        try:
            comm = open(f"/proc/{pid}/comm").read().strip()
            ppid = int(open(f"/proc/{pid}/stat").read().split()[3])
        except (OSError, IndexError, ValueError):
            break
        if comm == "ghostty":
            gpid = pid
            break
        if ppid in (0, pid):
            break
        pid = ppid
    if gpid is None:
        return None
    clients = run("hyprctl", "clients", "-j")
    if not clients:
        return None
    try:
        return next(c["address"] for c in json.loads(clients) if c.get("pid") == gpid)
    except (StopIteration, ValueError):
        return None


def _have(cmd: str) -> bool:
    return any(os.access(os.path.join(p, cmd), os.X_OK) for p in os.get_exec_path())


# Opacity for the neutral / no-project state ($HOME etc.) — a "ghostly when
# idle" cue. In a project the window is opaque (props reset to the global 1.0).
IDLE_ALPHA, IDLE_ALPHA_INACTIVE = 0.85, 0.72


def _setprop(addr: str, **props: object) -> None:
    """Set Hyprland window props. NB: for color props, -1 restores the global
    default; for alpha, -1 is taken literally and clamps to 0 (invisible!), so
    opacity must always be reset with an explicit 1, never -1."""
    for prop, val in props.items():
        run("hyprctl", "dispatch", "setprop", f"address:{addr}", prop, str(val))


def apply_window(active: str, inactive: str) -> None:
    """In a project: colored border + fully opaque (alpha explicitly 1)."""
    addr = ghostty_address()
    if addr:
        _setprop(addr, activebordercolor=active, inactivebordercolor=inactive,
                 alpha=1, alphainactive=1)


def reset_window() -> None:
    """Neutral state: default border + slight transparency."""
    addr = ghostty_address()
    if addr:
        _setprop(addr, activebordercolor=-1, inactivebordercolor=-1,
                 alpha=IDLE_ALPHA, alphainactive=IDLE_ALPHA_INACTIVE)


def write_tty(seq: str) -> None:
    try:
        with open(TTY, "w") as t:
            t.write(seq)
    except OSError:
        pass


def set_bg(hex6: str) -> None:
    write_tty(f"\033]11;#{hex6}\033\\")   # OSC 11 — set background


def reset_bg() -> None:
    write_tty("\033]111\033\\")            # OSC 111 — reset background


def scheme_is_light() -> bool:
    val = run("gsettings", "get", "org.gnome.desktop.interface", "color-scheme") or ""
    return "prefer-light" in val      # default to dark when unset/auto


def _rgb(hex6: str) -> tuple[int, int, int]:
    h = hex6.lstrip("#")
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def _hex(rgb: tuple[int, int, int]) -> str:
    return "%02x%02x%02x" % rgb


def _mix(a: tuple, b: tuple, f: float) -> tuple:
    # round half-up (int(x+0.5)) so output is bit-identical to term-ident.rb
    return tuple(int(a[i] * (1 - f) + b[i] * f + 0.5) for i in range(3))


def apply_seed(seed: str) -> None:
    t = THEME["light" if scheme_is_light() else "dark"]
    accent = _rgb(PALETTE[zlib.crc32(seed.encode()) % len(PALETTE)])
    theme_bg = _rgb(t["bg"])
    black = (0, 0, 0)

    bg = _mix(theme_bg, accent, t["frac"])               # accent blended into theme bg
    border = _mix(accent, black, t["border_darken"])     # darkened on light for contrast
    active = f"rgba({_hex(border)}ee) rgba({_hex(_mix(border, black, 0.30))}ee) 45deg"
    inactive = f"rgba({_hex(_mix(border, theme_bg, 0.45))}aa)"

    set_bg(_hex(bg))
    apply_window(active, inactive)


def reset_all() -> None:
    reset_bg()
    reset_window()


def main(argv: list[str]) -> int:
    cmd = argv[0] if argv else "project"
    if cmd == "reset":
        reset_all()
    elif cmd == "seed":
        apply_seed(argv[1]) if len(argv) > 1 and argv[1] else reset_all()
    elif cmd in ("project", ""):
        directory = argv[1] if len(argv) > 1 else os.getcwd()
        top = run("git", "-C", directory, "rev-parse", "--show-toplevel")
        apply_seed(top) if top else reset_all()
    else:
        print("usage: term-ident {project [dir]|seed <string>|reset}", file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
