#!/usr/bin/env bash
# Toggle or report the system color-scheme. Flips, in coordination:
#   - GNOME gsettings (color-scheme + gtk-theme)  -> chromium + GTK apps
#   - Hyprland border + tabbed-group colors        -> hyprctl keyword (Hyprland session)
#   - niri border colors                           -> ~/.config/niri/colors.kdl (niri session)
#   - Waybar CSS                                   -> ~/.config/waybar/style.css symlink + SIGUSR2
#   - Ghostty already auto-follows via `theme = light:X,dark:Y` in its config
#
# Compositor-aware: the hyprctl calls no-op under niri (guarded with `|| true`),
# and the niri colors.kdl write only fires under niri. The gsettings + waybar +
# ghostty paths are identical for both sessions.
#
# Usage:
#   toggle-color-scheme           -> flip dark <-> light
#   toggle-color-scheme --status  -> print waybar JSON for the current state
#   toggle-color-scheme --apply   -> apply current gsettings state everywhere (startup hook)
set -eu

SCHEMA=org.gnome.desktop.interface
DARK_THEME=Graphite-teal-Dark-nord
LIGHT_THEME=Graphite-teal-Light-nord
WAYBAR_SIGNAL=8

# Hyprland border palettes (steel-blue + desaturated teal)
DARK_ACTIVE='rgba(6b7a99ee) rgba(5c9090ee) 45deg'
DARK_INACTIVE='rgba(44444488)'
LIGHT_ACTIVE='rgba(3a4a6bee) rgba(2a6060ee) 45deg'
LIGHT_INACTIVE='rgba(bbbbbb88)'

# Tabbed-group (groupbar) palettes. Active tab reuses the border gradient;
# inactive tab is an opaque dim fill; text contrasts the scheme.
DARK_TAB_ACTIVE="$DARK_ACTIVE"
DARK_TAB_INACTIVE='rgba(2e3440dd)'
DARK_TAB_TEXT='rgba(e5e9f0ff)'
LIGHT_TAB_ACTIVE="$LIGHT_ACTIVE"
LIGHT_TAB_INACTIVE='rgba(d8dee9dd)'
LIGHT_TAB_TEXT='rgba(2e3440ff)'

WAYBAR_DIR="$HOME/.config/waybar"

# niri border palettes (KDL hex with alpha; same colors as the Hyprland rgba()).
NIRI_COLORS="$HOME/.config/niri/colors.kdl"
DARK_NIRI_FROM='#6b7a99ee';  DARK_NIRI_TO='#5c9090ee';  DARK_NIRI_INACTIVE='#44444488'
LIGHT_NIRI_FROM='#3a4a6bee'; LIGHT_NIRI_TO='#2a6060ee'; LIGHT_NIRI_INACTIVE='#bbbbbb88'

# Rewrite the niri border colors file (included by config.kdl). Only runs under
# niri; niri watches included files and live-reloads on write. niri has no
# tabbed-group color concept, so there's no groupbar analog to set.
write_niri_colors() {  # $1=from $2=to $3=inactive
    [ "${XDG_CURRENT_DESKTOP:-}" = "niri" ] || return 0
    mkdir -p "$(dirname "$NIRI_COLORS")"
    cat > "$NIRI_COLORS" <<EOF
// Border colors — RUNTIME-MANAGED by toggle-color-scheme. niri live-reloads this.
layout {
    border {
        active-gradient from="$1" to="$2" angle=45
        inactive-color "$3"
    }
}
EOF
}

apply_dark() {
    hyprctl keyword general:col.active_border "$DARK_ACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword general:col.inactive_border "$DARK_INACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword group:groupbar:col.active "$DARK_TAB_ACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword group:groupbar:col.inactive "$DARK_TAB_INACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword group:groupbar:text_color "$DARK_TAB_TEXT" >/dev/null 2>&1 || true
    write_niri_colors "$DARK_NIRI_FROM" "$DARK_NIRI_TO" "$DARK_NIRI_INACTIVE"
    ln -sfn style-dark.css "$WAYBAR_DIR/style.css"
}

apply_light() {
    hyprctl keyword general:col.active_border "$LIGHT_ACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword general:col.inactive_border "$LIGHT_INACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword group:groupbar:col.active "$LIGHT_TAB_ACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword group:groupbar:col.inactive "$LIGHT_TAB_INACTIVE" >/dev/null 2>&1 || true
    hyprctl keyword group:groupbar:text_color "$LIGHT_TAB_TEXT" >/dev/null 2>&1 || true
    write_niri_colors "$LIGHT_NIRI_FROM" "$LIGHT_NIRI_TO" "$LIGHT_NIRI_INACTIVE"
    ln -sfn style-light.css "$WAYBAR_DIR/style.css"
}

reload_waybar() {
    # SIGUSR2 reloads waybar's CSS + config (picks up the new symlink target).
    pkill -USR2  waybar 2>/dev/null || true
    # RTMIN+N tells waybar to re-exec the custom-color-scheme module (refreshes the moon/sun icon).
    pkill -RTMIN+"$WAYBAR_SIGNAL" waybar 2>/dev/null || true
}

current=$(gsettings get "$SCHEMA" color-scheme 2>/dev/null || echo "")

case "${1:-}" in
  --status)
    # Glyphs (Hack Nerd Font, Font Awesome range)
    moon=$''
    sun=$''
    auto=$''
    case "$current" in
      *prefer-dark*)  printf '{"text":"%s","tooltip":"color-scheme: prefer-dark (click to switch to light)","class":"dark"}\n'   "$moon" ;;
      *prefer-light*) printf '{"text":"%s","tooltip":"color-scheme: prefer-light (click to switch to dark)","class":"light"}\n' "$sun"  ;;
      *)              printf '{"text":"%s","tooltip":"color-scheme: default (click to switch to dark)","class":"auto"}\n'        "$auto" ;;
    esac
    exit 0
    ;;

  --apply)
    # Apply current scheme to the compositor (Hyprland borders or niri colors.kdl)
    # + waybar without flipping gsettings. Used at session startup so persistent
    # state matches what's set.
    case "$current" in
      *prefer-light*) apply_light ;;
      *)              apply_dark  ;;  # default to dark when unset/auto
    esac
    reload_waybar
    exit 0
    ;;
esac

# Default: toggle.
case "$current" in
  *prefer-dark*)
    gsettings set "$SCHEMA" color-scheme 'prefer-light'
    gsettings set "$SCHEMA" gtk-theme    "$LIGHT_THEME"
    apply_light
    ;;
  *)
    gsettings set "$SCHEMA" color-scheme 'prefer-dark'
    gsettings set "$SCHEMA" gtk-theme    "$DARK_THEME"
    apply_dark
    ;;
esac

reload_waybar
