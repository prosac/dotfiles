#!/usr/bin/env python3
"""Claude Code statusLine: render a per-session identity line at the bottom of
the Claude UI — the on-window cue for "which session is which" now that ghostty
title bars are hidden under Hyprland.

Shows  <glyph> <project>  "<first-prompt gist>"  <model>, coloured in the
session's accent. Glyph + accent + gist come from the per-session file written
by `term-ident-claude` on the first prompt (the same seed that colours the
window border), so the statusline and the border always agree. Before the first
prompt only the project name is shown, dimmed.

Reads the statusLine JSON on stdin; prints one line. Never crashes the bar.
"""
import json
import os
import sys

STATE_DIR = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "term-ident")

RESET = "\x1b[0m"
DIM = "\x1b[2m"
ITALIC = "\x1b[3m"


def accent_seq(hex6: str, bold: bool = False) -> str:
    h = hex6.lstrip("#")
    try:
        r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
    except (ValueError, IndexError):
        return ""
    return f"\x1b[{'1;' if bold else ''}38;2;{r};{g};{b}m"


def project_name(data: dict) -> str:
    ws = data.get("workspace") or {}
    path = ws.get("project_dir") or ws.get("current_dir") or data.get("cwd") or ""
    return os.path.basename(path.rstrip("/")) or "~"


def session_identity(data: dict) -> dict:
    sid = data.get("session_id") or ""
    safe_id = "".join(c for c in sid if c.isalnum() or c in "-_")
    try:
        with open(os.path.join(STATE_DIR, f"session-{safe_id}.json")) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError, ValueError):
        return {}


def main() -> int:
    try:
        data = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        return 0

    project = project_name(data)
    model = ((data.get("model") or {}).get("display_name") or "").strip()
    ident = session_identity(data)
    glyph, accent, gist = ident.get("glyph"), ident.get("accent"), ident.get("gist")

    parts = []
    if accent and glyph:
        parts.append(f"{accent_seq(accent, bold=True)}{glyph} {project}{RESET}")
    else:
        parts.append(f"{DIM}{project}{RESET}")
    if gist:
        parts.append(f"{DIM}{ITALIC}“{gist}”{RESET}")
    if model:
        parts.append(f"{DIM}{model}{RESET}")

    sys.stdout.write("  ".join(parts))
    return 0


if __name__ == "__main__":
    sys.exit(main())
