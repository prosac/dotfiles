# mise tasks for the NetBird management box.
#
# Generated by chezmoi from PRIVATE data ([data.netbird] in ~/.config/chezmoi/chezmoi.toml),
# which is NOT in the public dotfiles repo. Host + 1Password ref stay out of git.
# Because this is a .tmpl, do NOT `chezmoi re-add` it — edit the source template instead.

[tasks."netbird:ssh"]
description = "Root SSH into the NetBird box (key streamed from 1Password into an in-memory agent; never written to disk)"
run = """
ssh-agent bash -c 'op read "{{ .netbird.sshKeyRef }}" | ssh-add - >/dev/null && exec ssh -o IdentityAgent=$SSH_AUTH_SOCK {{ .netbird.sshUser }}@{{ .netbird.sshHost }}'
"""
