// -*- mode: jsonc -*-
// Hyprland-session waybar config. Selected by ~/.local/bin/waybar-launch when
// XDG_CURRENT_DESKTOP=Hyprland. Shares geometry, the right-hand cluster and all
// agnostic module definitions with the niri session via the include below; only
// the Hyprland-specific workspace/submap/window modules live here.
{
    "include": ["{{ .chezmoi.homeDir }}/.config/waybar/shared.jsonc"],

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "hyprland/window",
        "custom/hidden-windows"
    ],

    "hyprland/workspaces": {
        // Nerd Font glyphs use JSON \uXXXX escapes so the bytes survive
        // tooling that strips raw PUA characters.
        //    fa-chrome      fa-firefox     cust-emacs
        //    fa-terminal    folder-open    fa-folder
        //    sticky-note    slack          mdi-discord
        //    fa-envelope
        "format": "{name} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "·",
        "window-rewrite": {
            "class<chromium-browser>": "",
            "class<Chromium-browser>": "",
            "class<google-chrome>": "",
            "class<Google-chrome>": "",
            "class<firefox>": "",
            "class<[Ee]macs>": "",
            "class<com.mitchellh.ghostty>": "",
            "class<ghostty>": "",
            "class<org.kde.dolphin>": "",
            "class<io.gitlab.ilshat_apps.manuscript>": "",
            "class<org.gnome.Nautilus>": "",
            "class<Slack>": "",
            "class<discord>": "",
            "class<org.thunderbird.Thunderbird>": "",
            "class<thunderbird>": ""
        },
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "[{}]"
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 80,
        "separate-outputs": true
    }
}
