// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 2,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "custom/gradia",
        "custom/color-scheme",
        "custom/displays",
        "wireplumber",
        "bluetooth",
        "network",
        "battery",
        "clock",
        "tray"
    ],

    "custom/gradia": {
        "format": "scr",
        "tooltip": false,
        "on-click": "flatpak run be.alexandervanhee.gradia"
    },

    "custom/color-scheme": {
        "exec": "{{ .chezmoi.homeDir }}/.local/bin/toggle-color-scheme --status",
        "on-click": "{{ .chezmoi.homeDir }}/.local/bin/toggle-color-scheme",
        "return-type": "json",
        "interval": "once",
        "signal": 8
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "[{}]"
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 80,
        "separate-outputs": true
    },

    "custom/displays": {
        "format": "displays",
        "tooltip": false,
        "on-click": "nwg-displays"
    },

    "bluetooth": {
        "format": "bt",
        "format-off": "",
        "format-disabled": "",
        "format-connected": "bt ({num_connections})",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "blueman-manager"
    },

    "wireplumber": {
        "format": "{volume}%",
        "format-muted": "muted",
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "network": {
        "format-wifi": "{essid} {signalStrength}%",
        "format-ethernet": "{ifname}",
        "format-disconnected": "offline",
        "tooltip-format": "{ifname} · {ipaddr}"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}%",
        "format-charging": "+{capacity}%",
        "format-plugged": "{capacity}%"
    },

    "clock": {
        "format": "{:%a %Y-%m-%d  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    }
}
