// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 2,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "hyprland/window",
        "custom/hidden-windows"
    ],
    "modules-right": [
        "custom/gradia",
        "custom/color-scheme",
        "custom/displays",
        "backlight",
        "wireplumber",
        "bluetooth",
        "network",
        "battery",
        "clock",
        "tray"
    ],

    "custom/gradia": {
        "format": "scr",
        "tooltip": false,
        "on-click": "flatpak run be.alexandervanhee.gradia"
    },

    "custom/color-scheme": {
        "exec": "{{ .chezmoi.homeDir }}/.local/bin/toggle-color-scheme --status",
        "on-click": "{{ .chezmoi.homeDir }}/.local/bin/toggle-color-scheme",
        "return-type": "json",
        "interval": "once",
        "signal": 8
    },

    "hyprland/workspaces": {
        // Nerd Font glyphs use JSON \uXXXX escapes so the bytes survive
        // tooling that strips raw PUA characters.
        //    fa-chrome      fa-firefox     cust-emacs
        //    fa-terminal    folder-open    fa-folder
        //    sticky-note    slack          mdi-discord
        //    fa-envelope
        "format": "{name} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "·",
        "window-rewrite": {
            "class<chromium-browser>": "",
            "class<Chromium-browser>": "",
            "class<google-chrome>": "",
            "class<Google-chrome>": "",
            "class<firefox>": "",
            "class<[Ee]macs>": "",
            "class<com.mitchellh.ghostty>": "",
            "class<ghostty>": "",
            "class<org.kde.dolphin>": "",
            "class<io.gitlab.ilshat_apps.manuscript>": "",
            "class<org.gnome.Nautilus>": "",
            "class<Slack>": "",
            "class<discord>": "",
            "class<org.thunderbird.Thunderbird>": "",
            "class<thunderbird>": ""
        },
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "[{}]"
    },

    "custom/hidden-windows": {
        "exec": "{{ .chezmoi.homeDir }}/.local/bin/waybar-hidden-windows",
        "return-type": "json",
        "interval": "once"
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 80,
        "separate-outputs": true
    },

    "backlight": {
        "device": "amdgpu_bl1",
        "format": "{percent}%",
        "tooltip-format": "brightness {percent}%",
        "scroll-step": 5,
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "custom/displays": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "configure displays (nwg-displays)",
        "on-click": "nwg-displays"
    },

    "bluetooth": {
        "format": "bt",
        "format-off": "",
        "format-disabled": "",
        "format-connected": "bt ({num_connections})",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "blueman-manager"
    },

    "wireplumber": {
        "format": "{volume}%",
        "format-muted": "muted",
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-disconnected": "",
        "tooltip-format-wifi": "{essid} · {signalStrength}%\n{ifname} · {ipaddr}",
        "tooltip-format-ethernet": "{ifname} · {ipaddr}",
        "tooltip-format-disconnected": "network offline"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}%",
        "format-charging": "+{capacity}%",
        "format-plugged": "{capacity}%"
    },

    "clock": {
        "format": "{:%Y-%m-%d  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    }
}
