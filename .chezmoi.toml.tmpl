{{/* Rendered by `chezmoi init` to ~/.config/chezmoi/chezmoi.toml.
     `promptStringOnce` / `promptChoiceOnce` preserve values already set,
     so re-running init does not re-prompt for keys you've answered. */ -}}

{{- $name := promptStringOnce . "name" "Git name (user.name in .gitconfig)" -}}
{{- $email := promptStringOnce . "email" "Git email" -}}
{{- $machineClass := promptChoiceOnce . "machineClass" "Machine class" (list "laptop" "desktop") -}}
{{- $passwordManager := promptChoiceOnce . "passwordManager" "Password manager" (list "1password" "bitwarden" "none") -}}
{{- $mailSetup := promptBoolOnce . "mailSetup" "Deploy notmuch + lieer Gmail setup on this machine" false -}}

[data]
name = {{ $name | quote }}
email = {{ $email | quote }}
machineClass = {{ $machineClass | quote }}
passwordManager = {{ $passwordManager | quote }}
mailSetup = {{ $mailSetup }}
